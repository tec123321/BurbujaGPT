<resources>
    <style name="AppTheme" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">#25D366</item>
        <item name="android:navigationBarColor">#07110C</item>
        <item name="android:statusBarColor">#07110C</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:forceDarkAllowed">true</item>
    </style>

    <style name="NativeBubbleTheme" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">#101A14</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:colorAccent">#25D366</item>
        <item name="android:navigationBarColor">#07110C</item>
        <item name="android:forceDarkAllowed">true</item>
        <item name="android:windowDisablePreview">true</item>
    </style>
</resources>
